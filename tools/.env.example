MQTT_BROKER_URL=mqtts://localhost:8883

# Per-device passwords — copy values from mosquitto/devices.env after running setup.sh
MQTT_PASSWORD_LOCK_01=your-lock-01-password
MQTT_PASSWORD_LIGHTS_01=your-lights-01-password

# Path to the CA cert generated by mosquitto/setup.sh
MQTT_CA_CERT_PATH=../mosquitto/certs/ca.crt
