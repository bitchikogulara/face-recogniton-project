PORT=3000

# JWT — set a strong random secret (e.g. openssl rand -hex 32)
# Phase 2: generate this properly and keep it out of git
JWT_SECRET=change-me

# MQTT broker
MQTT_BROKER_URL=mqtts://localhost:8883
MQTT_USERNAME=gateway
MQTT_PASSWORD=your-gateway-password

# Path to the CA cert generated by mosquitto/setup.sh
MQTT_CA_CERT_PATH=../mosquitto/certs/ca.crt
